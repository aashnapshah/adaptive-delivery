# Copy to .env at the repo root and fill in a key. The harness auto-detects a backend
# (Gemini first, then OpenRouter, then a local Ollama, then an offline stub), or force one
# with DEMO_LLM_BACKEND. Gemini is the current default.

DEMO_LLM_BACKEND=gemini

# Gemini (Google AI Studio key). The default backend.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# OpenRouter (any model id the key can reach) — used for other benchmarking models.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Local Ollama (required for MIMIC runs — credentialed data may not go to a hosted API).
OLLAMA_MODEL=qwen3:32b
