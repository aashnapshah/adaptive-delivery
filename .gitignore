# ─── Secrets: NEVER commit ───────────────────────────────────────────────
.env
**/.env
*.key

# ─── Credentialed / copyrighted data: NEVER commit ───────────────────────
# MIMIC-IV = PhysioNet credentialed data under a DUA (no public redistribution).
# NEJM CPC cases = copyrighted. Transcripts + per-case ground truth derive from both.
# case source data (MIMIC admissions + NEJM CPC narratives)
harness/cases/data/
# recorded agent runs, exported CSVs/sweeps/figures derived from those runs
**/recordings/
# study store: study.db + participant event logs
app/data/
*.db

# ─── macOS / Python / envs ───────────────────────────────────────────────
.DS_Store
._*
__pycache__/
*.pyc
.ipynb_checkpoints/
venv/
.venv/
node_modules/

# ─── Original deck (embeds third-party paper figures) — kept local ───────
slides/presentation-1.pptx

# ─── Scratch render artifacts ────────────────────────────────────────────
demo/_fig_*.html
demo/_fig_*.png
demo/_preview*
demo/_report*
slides/_slide_*.html

# ─── Per-slide renders — keep only the combined deck (deck.pdf / deck.html) ─
slides/slide-*.png

# ─── Local Claude Code config / locks ────────────────────────────────────
/.claude/
**/settings.local.json
**/scheduled_tasks.lock

# recorded run transcripts + metadata + eval scores (derived from credentialed/copyrighted cases)
results/raw/
# readable chat exports - same credentialed/copyrighted content, just rendered
results/processed/chats/

# ─── Scratch: dead code / old-schema artifacts, kept out of the tree ──────
/scratch/
