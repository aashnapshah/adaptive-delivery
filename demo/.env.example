# Copy this file to demo/.env and fill in what you use. demo/.env is gitignored.

# --- Backend selection -------------------------------------------------------
# openrouter | ollama | stub   (leave unset to auto-detect: openrouter -> ollama -> stub)
# DEMO_LLM_BACKEND=openrouter

# --- OpenRouter (any model) --------------------------------------------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Any model slug from https://openrouter.ai/models
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct

# --- Ollama (local) ----------------------------------------------------------
# Requires `ollama serve` running and the model pulled (`ollama pull llama3.2:3b`)
OLLAMA_MODEL=llama3.2:3b
